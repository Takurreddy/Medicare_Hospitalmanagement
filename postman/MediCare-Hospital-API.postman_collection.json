        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Patient\",\n  \"email\": \"{{patientEmail}}\",\n  \"phone\": \"9999999999\",\n  \"age\": 29,\n  \"gender\": \"male\",\n  \"role\": \"patient\",\n  \"password\": \"{{patientPassword}}\"\n}"
