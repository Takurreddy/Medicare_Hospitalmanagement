      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "  const data = pm.response.json();",
              "  if (data.user && data.user.id) pm.environment.set('patientId', data.user.id);",
              "}"
            ]
          }
        }
